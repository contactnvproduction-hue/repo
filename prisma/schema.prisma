// Schema Prisma - New Vision Production Dashboard
// Base de données PostgreSQL pour déploiement sur Render

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── UTILISATEURS & AUTH ──────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  MONTEUR
  VIDÉASTE
  PHOTOGRAPHE
  COMMERCIAL
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(COMMERCIAL)
  avatar       String?
  specialty    String?
  disponible      Boolean   @default(true)
  phone           String?
  hasLogin        Boolean   @default(true)
  includeInSuivi  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  assignedProjects  ProjectMember[]
  assignedTasks     Task[]             @relation("AssignedTasks")
  createdTasks      Task[]             @relation("CreatedTasks")
  objectives        Objective[]
  notifications     Notification[]
  uploadedDocuments Document[]
  authoredNotes     ClientNote[]       @relation("AuthoredNotes")
  projectComments   ProjectComment[]   @relation("ProjectCommentAuthor")
  availability      TeamAvailability[]
  dailyCheckins     UserDailyCheckin[]
  dailyFollowUps    DailyClientFollowUp[]
  memberPayments    MemberPayment[]
  memberInvoices    MemberInvoice[]

  @@map("users")
}

// ─── CLIENTS (CRM) ───────────────────────────────────────────────────────────

enum ClientType {
  PARTICULIER
  ENTREPRISE
  AGENCE
}

enum ClientStatus {
  PROSPECT
  ACTIF
  EN_PAUSE
  ARCHIVÉ
}

enum ClientSource {
  INSTAGRAM
  YOUTUBE
  BOUCHE_A_OREILLE
  GOOGLE
  SITE_WEB
  RECOMMANDATION
  LINKEDIN
  AUTRE
}

model Client {
  id          String       @id @default(cuid())
  name        String
  company     String?
  siret       String?
  address     String?
  email       String?
  phone       String?
  avatar      String?
  type        ClientType   @default(PARTICULIER)
  status      ClientStatus @default(PROSPECT)
  source      ClientSource @default(AUTRE)
  relanceDate         DateTime?
  notes               String?
  onboardingChecklist Json?
  lastBilanDate       DateTime?  // Date du dernier bilan mensuel effectué
  nextBilanDate       DateTime?  // Prochain bilan programmé
  followUpEnabled     Boolean    @default(false) // Suivi mensuel opt-in (clients hors retainer)
  mensualise          Boolean    @default(false) // paiements récurrents prévus SANS engagement (prévisionnel roulant)
  mensualiteAmount    Float?     // montant récurrent prévu quand mensualise = true
  mensualiteFrequency String?    @default("MENSUEL") // MENSUEL | TRIMESTRIEL (ex : Fitness Park 2000€/trimestre)
  lastFollowUpAt      DateTime?  // dernière relance confirmée — le prompt « Client relancé ? » revient tous les 3 jours
  vatExempt           Boolean    @default(false) // client étranger : exonération de TVA (art. 259-1 du CGI, autoliquidation)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  projects        Project[]
  quotes          Quote[]
  invoices        Invoice[]
  documents       Document[]
  interactions    ClientInteraction[]
  prestas         Presta[]
  clientNotes     ClientNote[]
  socialKpis      SocialKPI[]
  retainers       ClientRetainer[]
  charges         ClientCharge[]
  adaResponses    AdaFormResponse[]
  adaNotes        Json?
  brief           ClientBrief?
  shootingPlans   ShootingPlan[]
  onboardingForm  ClientOnboardingForm?
  spotSelections  ClientSpotSelection[]
  contentTopics   ClientContentTopic[]
  products        ClientProduct[]
  followUps       ClientFollowUp[]

  @@map("clients")
}

model ClientInteraction {
  id        String   @id @default(cuid())
  clientId  String
  type      String
  content   String
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_interactions")
}

// ─── PROJETS ─────────────────────────────────────────────────────────────────

// ─── CATÉGORIES PROJETS (dynamiques, modifiables) ────────────────────────────

model ProjectCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("#7c3aed")
  icon      String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  projects  Project[]

  @@map("project_categories")
}

enum ProjectType {
  VIDEO_CORPORATE
  CLIP
  REPORTAGE
  SHOOTING_PHOTO
  MARIAGE
  ÉVÉNEMENT
  AUTRE
}

enum ProjectStatus {
  BRIEF_REÇU
  EN_PRODUCTION
  EN_POST_PRODUCTION
  EN_VALIDATION
  LIVRÉ
  ARCHIVÉ
}

model Project {
  id            String        @id @default(cuid())
  clientId      String
  categoryId    String?
  title         String
  type          ProjectType   @default(VIDEO_CORPORATE)
  status        ProjectStatus @default(BRIEF_REÇU)
  description   String?
  startDate     DateTime?
  deadline      DateTime?
  budget        Float?
  revisionsMax    Int           @default(2)
  revisionsUsed   Int           @default(0)
  deliveryLink    String?
  productionStep  Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category        ProjectCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  members         ProjectMember[]
  tasks           Task[]
  quotes          Quote[]
  invoices        Invoice[]
  documents       Document[]
  onboardingSteps OnboardingStep[]
  comments        ProjectComment[]
  deliverables    Deliverable[]

  @@map("projects")
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectComment {
  id         String   @id @default(cuid())
  projectId  String
  authorId   String?
  content    String
  authorName String
  mentions   String[]
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User?   @relation("ProjectCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@map("project_comments")
}

// ─── ONBOARDING ──────────────────────────────────────────────────────────────

model OnboardingStep {
  id          String    @id @default(cuid())
  projectId   String
  label       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("onboarding_steps")
}

// ─── TÂCHES ───────────────────────────────────────────────────────────────────

enum TaskPriority {
  URGENTE
  HAUTE
  NORMALE
  BASSE
}

enum TaskStatus {
  A_FAIRE
  EN_COURS
  EN_RÉVISION
  TERMINÉE
}

model TaskCategory {
  id      String   @id @default(cuid())
  name    String
  color   String   @default("#6366f1")
  options String[]
  order   Int      @default(0)
  tasks   Task[]

  @@map("task_categories")
}

model Task {
  id             String       @id @default(cuid())
  projectId      String?
  assignedToId   String?
  createdById    String?
  title          String
  description    String?
  priority       TaskPriority @default(NORMALE)
  status         TaskStatus   @default(A_FAIRE)
  categoryId     String?
  categoryValue  String?
  dueDate        DateTime?
  recurrence     String?      // DAILY | WEEKLY | BIWEEKLY | MONTHLY — la prochaine occurrence se crée à la complétion
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project    Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignedTo User?         @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User?         @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)
  category   TaskCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

// ─── OBJECTIFS ────────────────────────────────────────────────────────────────

enum ObjectivePeriod {
  MENSUEL
  TRIMESTRIEL
  ANNUEL
}

enum ObjectiveStatus {
  EN_COURS
  ATTEINT
  ÉCHOUÉ
  EN_PAUSE
}

model Objective {
  id           String            @id @default(cuid())
  userId       String?
  title        String
  description  String?
  category     String            @default("CA")
  period       ObjectivePeriod   @default(MENSUEL)
  targetValue  Float
  currentValue Float             @default(0)
  unit         String            @default("€")
  startDate    DateTime
  endDate      DateTime
  deadline     DateTime?
  status       ObjectiveStatus   @default(EN_COURS)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  snapshots ObjectiveSnapshot[]

  @@map("objectives")
}

model ObjectiveSnapshot {
  id          String    @id @default(cuid())
  objectiveId String
  value       Float
  note        String?
  date        DateTime
  createdAt   DateTime  @default(now())

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@map("objective_snapshots")
}

// ─── DEVIS ────────────────────────────────────────────────────────────────────

enum QuoteStatus {
  BROUILLON
  ENVOYÉ
  ACCEPTÉ
  REFUSÉ
  EXPIRÉ
}

model Quote {
  id         String      @id @default(cuid())
  clientId   String
  projectId  String?
  number     String      @unique
  status     QuoteStatus @default(BROUILLON)
  validated  Boolean     @default(false)
  issueDate  DateTime    @default(now())
  expiryDate DateTime?
  totalHT    Float       @default(0)
  totalTVA   Float       @default(0)
  totalTTC   Float       @default(0)
  discount   Float       @default(0)
  notes      String?
  cgv        String?
  pdfUrl     String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  client   Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project  Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lines    QuoteLine[]
  invoices Invoice[]

  @@map("quotes")
}

model QuoteLine {
  id          String @id @default(cuid())
  quoteId     String
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  vatRate     Float  @default(20)
  total       Float  @default(0)
  order       Int    @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_lines")
}

// ─── FACTURES ─────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  EN_ATTENTE
  PARTIELLEMENT_PAYÉE
  PAYÉE
  EN_RETARD
  ANNULÉE
}

enum InvoiceType {
  ACOMPTE
  SOLDE
  TOTALE
}

model Invoice {
  id         String        @id @default(cuid())
  clientId   String
  projectId  String?
  quoteId    String?
  number     String        @unique
  type       InvoiceType   @default(TOTALE)
  status     InvoiceStatus @default(EN_ATTENTE)
  paid       Boolean       @default(false)
  issueDate  DateTime      @default(now())
  dueDate    DateTime?
  totalHT    Float         @default(0)
  totalTVA   Float         @default(0)
  totalTTC   Float         @default(0)
  amountPaid Float         @default(0)
  notes      String?
  cgv        String?
  pdfUrl     String?
  forecastIncluded Boolean  @default(true) // compter cette facture dans le prévisionnel Sales
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  client   Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project  Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  quote    Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  lines    InvoiceLine[]
  payments Payment[]

  @@map("invoices")
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  vatRate     Float   @default(20)
  total       Float   @default(0)
  order       Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_lines")
}

// ─── PAIEMENTS ────────────────────────────────────────────────────────────────

enum PaymentMethod {
  VIREMENT
  CB
  ESPÈCES
  CHÈQUE
  AUTRE
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  amount    Float
  date      DateTime      @default(now())
  method    PaymentMethod @default(VIREMENT)
  reference String?
  confirmed Boolean       @default(false)
  notes     String?
  createdAt DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── DÉPENSES ─────────────────────────────────────────────────────────────────

enum ExpenseCategory {
  LOYER
  LOGICIELS
  MATÉRIEL
  SALAIRES
  FREELANCES
  DÉPLACEMENTS
  MARKETING
  FORMATION
  ASSURANCE
  AUTRE
}

model Expense {
  id            String          @id @default(cuid())
  category      ExpenseCategory @default(AUTRE)
  categoryLabel String?         // pôle personnalisé (customisable dans les paramètres)
  amount        Float
  date          DateTime        @default(now())
  description   String
  receipt       String?
  isRecurring   Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("expenses")
}

// Snapshot de trésorerie : solde de trésorerie renseigné à une date donnée
model TreasurySnapshot {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  balance   Float    // solde de trésorerie constaté
  note      String?
  createdAt DateTime @default(now())

  @@map("treasury_snapshots")
}

// Investissements planifiés mois par mois (pilotage croissance)
model InvestmentPlan {
  id        String   @id @default(cuid())
  month     String   // "YYYY-MM"
  label     String
  pole      String?  // pôle / catégorie
  amount    Float
  done      Boolean  @default(false) // investissement réalisé
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("investment_plans")
}

// ─── DOCUMENTS ────────────────────────────────────────────────────────────────

enum DocumentType {
  CONTRAT
  BON_DE_COMMANDE
  BRIEF
  CHARTE_GRAPHIQUE
  LIVRABLE
  FACTURE
  DEVIS
  AUTRE
}

model Document {
  id           String       @id @default(cuid())
  clientId     String?
  projectId    String?
  uploadedById String?
  name         String
  type         DocumentType @default(AUTRE)
  url          String
  size         Int?
  mimeType     String?
  shareToken   String?      @unique
  shareExpiry  DateTime?
  version      Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedBy User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@map("documents")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

enum NotificationType {
  FACTURE_EN_RETARD
  DEADLINE_APPROCHE
  DEVIS_ACCEPTÉ
  TÂCHE_ASSIGNÉE
  ONBOARDING_INCOMPLET
  PAIEMENT_REÇU
  PROJET_MIS_A_JOUR
  GÉNÉRAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(GÉNÉRAL)
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── PARAMÈTRES AGENCE ────────────────────────────────────────────────────────

model AgencySetting {
  id             String   @id @default(cuid())
  name           String   @default("New Vision Production")
  email          String   @default("contact@newvision.fr")
  phone          String?
  address        String?
  siret          String?
  tvaNumber      String?
  logo           String?
  defaultVatRate Float    @default(20)
  cgv            String?
  invoicePrefix  String   @default("FAC")
  quotePrefix    String   @default("DEV")
  invoiceCounter Int      @default(1)
  quoteCounter   Int      @default(1)
  bankDetails    String?
  youtubeApiKey  String?
  apifyToken     String?  // token Apify pour scraper Instagram (data reels/posts complète)
  anthropicApiKey String? // clé API Claude pour l'analyse des bilans par screenshot (vision)
  metaAppId      String?  // Meta app id — rafraîchissement auto des tokens Instagram Graph
  metaAppSecret  String?  // Meta app secret (idem)
  adaSheetUrl    String?  // URL de la Google Sheet réponses ADA (publique)
  closingScriptUrl String? // lien vers le script de closing B2B (ouvert en 1 clic depuis le pipeline)
  expensePoles   Json?    // pôles de charges personnalisés [{ name, color }]
  corporateTaxRate Float  @default(25) // legacy — remplacé par le barème progressif auto
  isReducedRate  Boolean  @default(true) // éligible au taux réduit d'IS (15% jusqu'à 42 500 €)
  updatedAt      DateTime @updatedAt

  @@map("agency_settings")
}

// ─── PRESTATIONS ─────────────────────────────────────────────────────────────

enum PrestaStatus {
  EN_ATTENTE
  EN_COURS
  TERMINÉE
  ANNULÉE
}

model Presta {
  id               String       @id @default(cuid())
  clientId         String
  title            String
  description      String?
  contractedAmount Float        @default(0)
  collectedAmount  Float        @default(0)
  status           PrestaStatus @default(EN_COURS)
  signedQuoteFile  String?
  invoiceFile      String?
  startDate        DateTime?
  endDate          DateTime?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("prestas")
}

// ─── NOTES INTERNES CLIENT ────────────────────────────────────────────────────

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  authorId  String?
  content   String
  mentions  String[]
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User?  @relation("AuthoredNotes", fields: [authorId], references: [id], onDelete: SetNull)

  @@map("client_notes")
}

// ─── TRÉSORERIE / PRÉVISIONNEL ────────────────────────────────────────────────

enum CashEntryType {
  REVENU
  CHARGE
  SALAIRE
  TVA_COLLECTEE
  TVA_DEDUCTIBLE
  IMPOT
  AUTRE
}

model CashEntry {
  id          String        @id @default(cuid())
  type        CashEntryType @default(REVENU)
  category    String?
  amount      Float
  description String?
  date        DateTime
  recurring   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("cash_entries")
}

// ─── DISPONIBILITÉ ÉQUIPE ─────────────────────────────────────────────────────

model TeamAvailability {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  hours     Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@map("team_availability")
}

// ─── KPI SOCIAUX ──────────────────────────────────────────────────────────────

enum SocialPlatform {
  INSTAGRAM
  YOUTUBE
  TIKTOK
  LINKEDIN
  FACEBOOK
}

// ─── LIVRABLES PROJETS ───────────────────────────────────────────────────────

model DeliverableCategory {
  id          String        @id @default(cuid())
  name        String
  color       String        @default("#6366f1")
  order       Int           @default(0)
  createdAt   DateTime      @default(now())

  deliverables Deliverable[]

  @@map("deliverable_categories")
}

model Deliverable {
  id           String    @id @default(cuid())
  projectId    String
  categoryId   String?
  title        String
  description  String?
  quantity     Int       @default(1)
  month        DateTime?
  status       String    @default("EN_COURS")
  taskId       String?
  assignedTo   String[]
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project  Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category DeliverableCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("deliverables")
}

// ─── ACQUISITION / LEADS ─────────────────────────────────────────────────────

model LeadStatus {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  order     Int      @default(0)
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())

  leads     Lead[]

  @@map("lead_statuses")
}

model Lead {
  id                String    @id @default(cuid())
  statusId          String?
  name              String
  company           String?
  email             String?
  phone             String?
  source            String?
  budget            Float?
  notes             String?
  followUpDate      DateTime?
  convertedClientId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  status LeadStatus? @relation(fields: [statusId], references: [id], onDelete: SetNull)
  calls  LeadCall[]

  @@map("leads")
}

model LeadCall {
  id             String   @id @default(cuid())
  leadId         String
  date           DateTime
  duration       Int?
  showedUp       Boolean  @default(false) // le prospect s'est présenté au call
  qualified      Boolean  @default(false) // prospect qualifié
  closed         Boolean  @default(false) // le call a débouché sur une signature
  followUpNeeded Boolean  @default(false) // un follow-up est à faire
  followUpDone   Boolean  @default(false) // le follow-up a été effectué
  notes          String?
  createdAt      DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_calls")
}

// Closings (signatures) — inclut les nouveaux clients ET les re-closes de
// clients existants (upsell, nouvel engagement, renouvellement). Alimente les KPIs.
model ClosingEvent {
  id          String   @id @default(cuid())
  leadId      String?
  clientId    String?
  clientName  String
  type        String   @default("NEW") // NEW | UPSELL | RENEWAL
  missionType String?  // MRR | PONCTUEL
  amount      Float?   // montant mensuel (MRR) ou total (ponctuel)
  notes       String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("closing_events")
}

// ─── RETAINERS MRR ───────────────────────────────────────────────────────────

model ClientRetainer {
  id             String   @id @default(cuid())
  clientId       String
  description    String
  monthlyAmount  Float
  startDate      DateTime
  durationMonths Int
  forecastIncluded Boolean @default(true) // compter ce retainer dans le prévisionnel Sales
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_retainers")
}

// ─── RELANCES CLIENTS (« Client relancé ? » tous les 3 jours) ────────────────

model ClientFollowUp {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  callPlanned Boolean  @default(false) // un call de follow-up est planifié
  createdAt   DateTime @default(now())

  @@map("client_follow_ups")
}

// ─── CONTENU ORGANIQUE (tracking multi-comptes) ──────────────────────────────

// Un canal = un compte (personne + plateforme). Ex: Noah/Instagram, Maël/YouTube, NV/YouTube
model ContentChannel {
  id             String   @id @default(cuid())
  owner          String   // libellé libre : "Noah", "Maël", "New Vision"
  platform       String   // INSTAGRAM | YOUTUBE | TIKTOK
  handle         String?
  url            String
  followers      Int?
  accessToken    String?  // Instagram Graph API : token longue durée (compte Business/Creator)
  platformUserId String?  // Instagram Graph API : identifiant du compte IG Business
  tokenExpiresAt DateTime? // expiration du token longue durée (rafraîchi auto à chaque sync)
  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pieces ContentPiece[]

  @@map("content_channels")
}

// Une publication (reel, short, long, post) avec ses stats
model ContentPiece {
  id             String   @id @default(cuid())
  channelId      String
  channel        ContentChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  externalId     String?  // id YouTube/plateforme (dédup)
  title          String
  url            String?
  thumbnail      String?
  format         String   @default("AUTRE") // SHORT | LONG | REEL | POST | AUTRE
  publishedAt    DateTime
  views          Int      @default(0)
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  engagementRate Float    @default(0) // (likes+comments+shares)/views * 100
  manual         Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([channelId, externalId])
  @@map("content_pieces")
}

// ─── CHARGES CLIENTS ─────────────────────────────────────────────────────────

model ClientCharge {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month     DateTime // premier jour du mois
  category  String   // ex: "Frais déplacement", "Location studio"
  amount    Float
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_charges")
}

// ─── SUIVI QUOTIDIEN CLIENT (relances équipe) ─────────────────────────────────

model DailyClientFollowUp {
  id          String   @id @default(cuid())
  memberName  String   // Nom du membre (saisi sur la page externe)
  userId      String?  // Lien optionnel vers un User du dashboard
  date        String   // "2026-06-20" — 1 par client par jour (multiple autorisé)
  clientName  String?  // legacy — gardé pour migration non-destructive
  clientNames String[] // clients relancés (array, utilisé par le nouveau formulaire)
  types       String[] // ["relance_client", "avancement_livrable", ...]
  notes       String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("daily_client_follow_ups")
}

// ─── FORMULAIRE ADA (réponses Google Forms) ──────────────────────────────────

model AdaFormResponse {
  id                 String   @id @default(cuid())
  clientId           String?
  client             Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  responseTimestamp  String   @unique // "Horodateur" Google Forms — clé de déduplication
  data               Json     // toutes les réponses du formulaire (clé = question, valeur = réponse)
  matchedOn          String?  // valeur utilisée pour le match (ex: "Thibault Dupont")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("ada_form_responses")
}

// ─── DAILY CHECKIN ───────────────────────────────────────────────────────────

model UserDailyCheckin {
  id        String   @id @default(cuid())
  userId    String
  date      String   // "2026-06-04" — one per user per day
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("user_daily_checkins")
}

// ─── CONTRATS SIGNÉS (Plateforme Signature) ──────────────────────────────────

model SignedContract {
  id             String    @id @default(cuid())
  shortCode      String    @unique // ex: "NVP-A1B2C3"
  // Infos client
  clientName     String
  clientEmail    String?
  clientCompany  String?
  clientAddress  String?
  // Mission
  missionType    String    @default("MRR") // MRR | PONCTUEL
  monthlyAmount  Float?
  totalAmount    Float?
  durationMonths Int?
  startDate      String?
  currency       String    @default("EUR")
  depositAmount  Float?
  depositPercent Int?
  // Livrables (JSON array)
  deliverables   Json      @default("[]")
  // Données complètes pour régénérer le PDF
  contractData   Json?
  // Signature
  signedAt       DateTime?
  signeeName     String?
  signatureIp    String?
  // Statut
  status         String    @default("PENDING") // PENDING | SIGNED | ARCHIVED
  // Liens vers le dashboard NV
  clientId       String?
  projectId      String?
  leadId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("signed_contracts")
}

// ─── ESPACE CEO ───────────────────────────────────────────────────────────────

model CeoMeeting {
  id        String          @id @default(cuid())
  title     String
  date      DateTime
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  topics      MeetingTopic[]
  actionSteps CeoActionStep[]

  @@map("ceo_meetings")
}

model MeetingTopic {
  id        String     @id @default(cuid())
  meetingId String
  content   String
  done      Boolean    @default(false)
  order     Int        @default(0)
  createdAt DateTime   @default(now())

  meeting CeoMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_topics")
}

// Calls récurrents hebdomadaires (point contenu, point delivery…)
model RecurringCall {
  id        String   @id @default(cuid())
  title     String
  dayOfWeek Int      // 0 = lundi … 6 = dimanche
  time      String?  // "14:00"
  withWho   String?  // participant(s) : Maël, équipe…
  color     String   @default("#e8b84b")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes RecurringCallNote[]

  @@map("recurring_calls")
}

// Notes / sujets à préparer pour UNE occurrence précise d'un call récurrent
model RecurringCallNote {
  id        String        @id @default(cuid())
  callId    String
  call      RecurringCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  date      String        // "2026-07-13" — date de l'occurrence
  content   String?       // sujets à aborder, notes de préparation
  done      Boolean       @default(false) // point effectué
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([callId, date])
  @@map("recurring_call_notes")
}

model CeoActionStep {
  id        String      @id @default(cuid())
  meetingId String?
  taskId    String?
  content   String
  done      Boolean     @default(false)
  dueDate   DateTime?
  assignee  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  meeting CeoMeeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  @@map("ceo_action_steps")
}

