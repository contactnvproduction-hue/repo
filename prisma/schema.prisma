// ─── KPI SOCIAUX ──────────────────────────────────────────────────────────────

// ─── RÉMUNÉRATIONS ÉQUIPE ─────────────────────────────────────────────────────

enum MemberPaymentType {
  SALAIRE
  FREELANCE
  BONUS
}

model MemberPayment {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float
  month     String            // format "YYYY-MM"
  type      MemberPaymentType @default(FREELANCE)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, month, type])
  @@map("member_payments")
}

// Suivi de la collecte des factures freelances. Chaque membre doit transmettre
// sa facture avant le 28 du mois ; règlement le 1er du mois suivant. Passé le 28,
// les factures non transmises sont reportées au cycle suivant.
model MemberInvoice {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month         String   // "YYYY-MM" — mois de travail concerné (deadline le 28)
  hasInvoice    Boolean  @default(true) // y a-t-il une facture à transmettre ce mois ?
  status        String   @default("EN_ATTENTE") // EN_ATTENTE | TRANSMISE | REPORTEE | PAYEE
  amount        Float?   // (déprécié — les salaires sont calculés dans Finance)
  transmittedAt DateTime? // date de transmission de la facture
  paidAt        DateTime? // date de règlement (1er du mois suivant)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, month])
  @@map("member_invoices")
}

// ─── FORMULAIRE D'ONBOARDING CLIENT (public, remplace Google Forms) ──────────

model ShootingSpot {
  id          String   @id @default(cuid())
  name        String
  city        String
  address     String?
  category    String?  // modulable : Café / Terrasse, Studio, Hôtel / Luxe…
  description String?
  tags        String[]
  photos      String[]
  photosFull  Boolean[] // aligné sur photos : true = afficher en grand format complet (sans crop)
  supplement  String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  selections  ClientSpotSelection[]

  @@map("shooting_spots")
}

model ClientSpotSelection {
  id        String       @id @default(cuid())
  clientId  String
  spotId    String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  spot      ShootingSpot @relation(fields: [spotId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([clientId, spotId])
  @@map("client_spot_selections")
}

model ClientOnboardingForm {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Identité
  firstName String?
  lastName  String?

  // Branding
  brandName          String?
  acquisitionChannels String[]
  inspirationLinks    String[]
  inspirationNotes    String?
  visualPerception    String[]
  editingStyles       String[]
  mustHighlight       String?
  mustAvoid           String?
  brandFont           String?
  musicVibe           String?
  callToAction        String?

  // ICP
  icpSector       String?
  icpTargetAge    String?
  icpTargetStatus String?
  icpTargetProblem String?
  icpOffer         String?
  icpTone          String?

  // Documents uploadés par le client (base64 data-URLs — le disque Render est éphémère)
  icpPdf              String?  // PDF avatar client
  icpPdfName          String?
  channelsScreenshot  String?  // legacy — capture unique (remplacé par channelsScreenshots)
  channelsScreenshots String[] // captures des canaux d'acquisition (une par canal, tracking début de collab)

  // Réponses aux questions personnalisées ajoutées depuis le dashboard (clé = question key)
  customAnswers Json?

  status      String   @default("pending") // pending | completed
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("client_onboarding_forms")
}

// Configuration éditable des questions du formulaire d'onboarding (singleton)
model OnboardingConfig {
  id        String   @id @default("main")
  questions Json     // [{ key, label, hint, options, active, custom, step }]
  videoUrl  String?  // lien YouTube (non répertorié) de la vidéo d'introduction du formulaire
  updatedAt DateTime @updatedAt

  @@map("onboarding_config")
}

// ─── PRODUITS / OFFRES ────────────────────────────────────────────────────────

// Catalogue de produits personnalisables (offre batch content, documentaire, montage…)
model Product {
  id           String   @id @default(cuid())
  name         String
  color        String   @default("#e8b84b")
  defaultPrice Float?
  active       Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientProducts ClientProduct[]

  @@map("products")
}

// Produits vendus à un client (au close ou ajoutés depuis la fiche client/projet)
model ClientProduct {
  id        String   @id @default(cuid())
  clientId  String
  productId String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  amount    Float    @default(0) // montant total facturé pour cette ligne
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_products")
}

// Sujets de contenu prédéfinis par client (basés sur l'ICP de l'onboarding)
model ClientContentTopic {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  notes     String?
  status    String   @default("IDEE") // IDEE | VALIDE | TOURNE | PUBLIE
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_content_topics")
}

// ─── SOCIAL KPIs ──────────────────────────────────────────────────────────────

model SocialKPI {
  id             String         @id @default(cuid())
  clientId       String
  platform       SocialPlatform
  handle         String?
  channelUrl     String?
  month          DateTime
  followers      Int            @default(0)
  views          Int?
  likes          Int?
  comments       Int?
  shares         Int?
  engagement     Float?
  revenue        Float?     // CA généré ce mois (pour corrélation croissance/CA)
  screenshotUrl  String?
  screenshotDate DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, platform, month])
  @@map("social_kpis")
}

